<%- include('../layout-start', { pageTitle: customer ? 'Edit Customer' : 'Add Customer' }) %>

        <div class="card">
                <div class="card-body">
                        <% if (typeof error !=='undefined' && error) { %>
                                <div class="alert alert-error">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <line x1="12" y1="8" x2="12" y2="12"></line>
                                                <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                        </svg>
                                        <%= error %>
                                </div>
                                <% } %>

                                        <form method="POST"
                                                action="/admin/customers<%= customer && customer.id ? '/' + customer.id + '/update' : '' %>">

                                                <!-- Section 1: Company -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2">
                                                                </rect>
                                                                <line x1="3" y1="9" x2="21" y2="9"></line>
                                                                <line x1="9" y1="21" x2="9" y2="9"></line>
                                                        </svg>
                                                        Company Details
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="companyName">Company Name *</label>
                                                                <input type="text" id="companyName" name="companyName"
                                                                        value="<%= customer ? customer.companyName || '' : '' %>"
                                                                        required placeholder="Enter company name">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="companyPhone">Company Phone Number *</label>
                                                                <input type="tel" id="companyPhone" name="companyPhone"
                                                                        value="<%= customer ? customer.companyPhone || '' : '' %>"
                                                                        required placeholder="Enter phone number">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="email">Company Email *</label>
                                                                <input type="email" id="email" name="email"
                                                                        value="<%= customer ? customer.email || '' : '' %>"
                                                                        required placeholder="you@example.com">
                                                        </div>
                                                        <div class="form-group full-width">
                                                                <label for="companyAddr">Company Address (Billing
                                                                        Address) *</label>
                                                                <input type="text" id="companyAddr" name="companyAddr"
                                                                        value="<%= customer ? customer.companyAddr || '' : '' %>"
                                                                        required placeholder="Enter billing address">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="country">Company Country *</label>
                                                                <input type="text" id="country" name="country"
                                                                        value="<%= customer ? customer.country || '' : '' %>"
                                                                        required placeholder="Enter country">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="zipCode">Zip Code *</label>
                                                                <input type="text" id="zipCode" name="zipCode"
                                                                        value="<%= customer ? customer.zipCode || '' : '' %>"
                                                                        required placeholder="Enter zip code">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="taxId">Tax ID/ABN/VAT Number *</label>
                                                                <input type="text" id="taxId" name="taxId"
                                                                        value="<%= customer ? customer.taxId || '' : '' %>"
                                                                        required placeholder="Enter tax ID">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="regCertUrl">Registration Certificate
                                                                        URL</label>
                                                                <input type="text" id="regCertUrl" name="regCertUrl"
                                                                        value="<%= customer ? customer.regCertUrl || '' : '' %>"
                                                                        placeholder="https://...">
                                                        </div>
                                                </div>

                                                <!-- Section 2: Bank -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <path
                                                                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z">
                                                                </path>
                                                                <polyline points="14 2 14 8 20 8"></polyline>
                                                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                                                <polyline points="10 9 9 9 8 9"></polyline>
                                                        </svg>
                                                        Bank Details
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="bankName">Bank Name *</label>
                                                                <input type="text" id="bankName" name="bankName"
                                                                        value="<%= customer ? customer.bankName || '' : '' %>"
                                                                        required placeholder="Enter bank name">
                                                        </div>
                                                        <div class="form-group full-width">
                                                                <label for="bankAddress">Bank Address *</label>
                                                                <input type="text" id="bankAddress" name="bankAddress"
                                                                        value="<%= customer ? customer.bankAddress || '' : '' %>"
                                                                        required placeholder="Enter bank address">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="bankCountry">Bank Country *</label>
                                                                <input type="text" id="bankCountry" name="bankCountry"
                                                                        value="<%= customer ? customer.bankCountry || '' : '' %>"
                                                                        required placeholder="Enter bank country">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="bankIban">IBAN *</label>
                                                                <input type="text" id="bankIban" name="bankIban"
                                                                        value="<%= customer ? customer.bankIban || '' : '' %>"
                                                                        required placeholder="Enter IBAN">
                                                        </div>
                                                </div>

                                                <!-- Section 3: CEO Details -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2">
                                                                </path>
                                                                <circle cx="12" cy="7" r="4"></circle>
                                                        </svg>
                                                        CEO Details
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="ceoName">CEO Name *</label>
                                                                <input type="text" id="ceoName" name="ceoName"
                                                                        value="<%= customer ? customer.ceoName || '' : '' %>"
                                                                        required placeholder="Enter CEO name">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="ceoPhone">CEO Phone Number *</label>
                                                                <input type="tel" id="ceoPhone" name="ceoPhone"
                                                                        value="<%= customer ? customer.ceoPhone || '' : '' %>"
                                                                        required placeholder="Enter phone number">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="ceoEmail">CEO Email *</label>
                                                                <input type="email" id="ceoEmail" name="ceoEmail"
                                                                        value="<%= customer ? customer.ceoEmail || '' : '' %>"
                                                                        required placeholder="Enter email address">
                                                        </div>
                                                </div>

                                                <!-- Section 4: Contact Person Sale Detail -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2">
                                                                </path>
                                                                <circle cx="9" cy="7" r="4"></circle>
                                                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                                        </svg>
                                                        Contact Person Sale Detail
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="salesName">Name *</label>
                                                                <input type="text" id="salesName" name="salesName"
                                                                        value="<%= customer ? customer.salesName || '' : '' %>"
                                                                        required placeholder="Enter name">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="salesEmail">Email *</label>
                                                                <input type="email" id="salesEmail" name="salesEmail"
                                                                        value="<%= customer ? customer.salesEmail || '' : '' %>"
                                                                        required placeholder="Enter email">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="salesPhone">Phone number *</label>
                                                                <input type="tel" id="salesPhone" name="salesPhone"
                                                                        value="<%= customer ? customer.salesPhone || '' : '' %>"
                                                                        required placeholder="Enter phone number">
                                                        </div>
                                                </div>

                                                <!-- Section 5: Person Purchase Details -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <circle cx="9" cy="21" r="1"></circle>
                                                                <circle cx="20" cy="21" r="1"></circle>
                                                                <path
                                                                        d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6">
                                                                </path>
                                                        </svg>
                                                        Person Purchase Details
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="purchaseName">Name *</label>
                                                                <input type="text" id="purchaseName" name="purchaseName"
                                                                        value="<%= customer ? customer.purchaseName || '' : '' %>"
                                                                        required placeholder="Enter name">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="purchaseEmail">Email *</label>
                                                                <input type="email" id="purchaseEmail"
                                                                        name="purchaseEmail"
                                                                        value="<%= customer ? customer.purchaseEmail || '' : '' %>"
                                                                        required placeholder="Enter email">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="purchasePhone">Phone number *</label>
                                                                <input type="tel" id="purchasePhone"
                                                                        name="purchasePhone"
                                                                        value="<%= customer ? customer.purchasePhone || '' : '' %>"
                                                                        required placeholder="Enter phone number">
                                                        </div>
                                                </div>

                                                <!-- Section 6: Logistic Manager Detail -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <path
                                                                        d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                                                                </path>
                                                                <polyline points="3.27 6.96 12 12.01 20.73 6.96">
                                                                </polyline>
                                                                <line x1="12" y1="22.08" x2="12" y2="12"></line>
                                                        </svg>
                                                        Logistic Manager Detail
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="logisticName">Name *</label>
                                                                <input type="text" id="logisticName" name="logisticName"
                                                                        value="<%= customer ? customer.logisticName || '' : '' %>"
                                                                        required placeholder="Enter name">
                                                        </div>
                                                        <div class="form-group full-width">
                                                                <label for="logisticPhone">Phone number *</label>
                                                                <input type="tel" id="logisticPhone"
                                                                        name="logisticPhone"
                                                                        value="<%= customer ? customer.logisticPhone || '' : '' %>"
                                                                        required placeholder="Enter phone number">
                                                        </div>
                                                </div>

                                                <!-- Section 7: Personal Information -->
                                                <h3 class="section-title">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="2" stroke-linecap="round"
                                                                stroke-linejoin="round" class="section-icon">
                                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2">
                                                                </path>
                                                                <circle cx="12" cy="7" r="4"></circle>
                                                        </svg>
                                                        Personal Information
                                                </h3>
                                                <div class="form-grid">
                                                        <div class="form-group full-width">
                                                                <label for="personalName">Name *</label>
                                                                <input type="text" id="personalName" name="personalName"
                                                                        value="<%= customer ? customer.personalName || '' : '' %>"
                                                                        required placeholder="Enter name">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="personalEmail">Email *</label>
                                                                <input type="email" id="personalEmail"
                                                                        name="personalEmail"
                                                                        value="<%= customer ? customer.personalEmail || '' : '' %>"
                                                                        required placeholder="Enter email">
                                                        </div>
                                                        <div class="form-group">
                                                                <label for="personalPhone">Phone number *</label>
                                                                <input type="tel" id="personalPhone"
                                                                        name="personalPhone"
                                                                        value="<%= customer ? customer.personalPhone || '' : '' %>"
                                                                        required placeholder="Enter phone number">
                                                        </div>
                                                </div>

                                                <% if (customer && customer.id) { %>
                                                        <h3 class="section-title">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="18"
                                                                        height="18" viewBox="0 0 24 24" fill="none"
                                                                        stroke="currentColor" stroke-width="2"
                                                                        stroke-linecap="round" stroke-linejoin="round"
                                                                        class="section-icon">
                                                                        <path
                                                                                d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z">
                                                                        </path>
                                                                        <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                                                </svg>
                                                                Customer Tags
                                                        </h3>
                                                        <div style="margin-bottom:20px;">
                                                                <p class="text-muted"
                                                                        style="font-size:12px;margin-bottom:12px;">
                                                                        Tags control which private products this
                                                                        customer can see. Assign tags that match
                                                                        visibility rules to grant access.</p>

                                                                <div style="margin-bottom:14px;">
                                                                        <label
                                                                                style="font-size:12px;font-weight:600;color:#475569;margin-bottom:6px;display:block;">Current
                                                                                Tags</label>
                                                                        <div
                                                                                style="display:flex;flex-wrap:wrap;gap:6px;min-height:32px;padding:8px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
                                                                                <% if (customer.tags &&
                                                                                        customer.tags.length> 0) { %>
                                                                                        <% customer.tags.forEach(tag=> {
                                                                                                %>
                                                                                                <span
                                                                                                        style="display:inline-flex;align-items:center;gap:4px;background:#fef3c7;color:#92400e;padding:4px 10px;border-radius:14px;font-size:13px;border:1px solid #fde68a;">
                                                                                                        <%= tag %>
                                                                                                                <button type="button"
                                                                                                                        style="background:none;border:none;color:#92400e;cursor:pointer;font-size:15px;padding:0;line-height:1;"
                                                                                                                        title="Remove tag"
                                                                                                                        onclick="document.getElementById('removeTagInput-<%= customer.id %>').value='<%= tag %>'; document.getElementById('removeTagForm-<%= customer.id %>').submit();">&times;</button>
                                                                                                </span>
                                                                                                <% }) %>
                                                                                                        <% } else { %>
                                                                                                                <span class="text-muted"
                                                                                                                        style="font-size:13px;">No
                                                                                                                        tags
                                                                                                                        assigned</span>
                                                                                                                <% } %>
                                                                        </div>
                                                                </div>

                                                                <label
                                                                        style="font-size:12px;font-weight:600;color:#475569;margin-bottom:6px;display:block;">Add
                                                                        Tag</label>
                                                                <div style="display:flex;gap:8px;align-items:flex-end;">
                                                                        <div class="form-group"
                                                                                style="margin-bottom:0;flex:1;max-width:200px;">
                                                                                <select name="tag"
                                                                                        form="addTagForm-<%= customer.id %>"
                                                                                        class="filter-select"
                                                                                        style="width:100%;font-size:13px;padding:6px 10px;"
                                                                                        onchange="document.querySelector('.new-tag-wrap').style.display=this.value==='__new__'?'block':'none'">
                                                                                        <option value="">Select tag...
                                                                                        </option>
                                                                                        <% if (typeof allTags
                                                                                                !=='undefined' ) {
                                                                                                allTags.forEach(t=> { %>
                                                                                                <option
                                                                                                        value="<%= t %>">
                                                                                                        <%= t %>
                                                                                                </option>
                                                                                                <% }) } %>
                                                                                                        <option
                                                                                                                value="__new__">
                                                                                                                + New
                                                                                                                Tag
                                                                                                        </option>
                                                                                </select>
                                                                        </div>
                                                                        <div class="form-group new-tag-wrap"
                                                                                style="margin-bottom:0;display:none;flex:1;max-width:200px;">
                                                                                <input type="text" name="newTag"
                                                                                        form="addTagForm-<%= customer.id %>"
                                                                                        placeholder="Enter new tag..."
                                                                                        style="font-size:13px;padding:6px 10px;">
                                                                        </div>
                                                                        <button type="submit"
                                                                                form="addTagForm-<%= customer.id %>"
                                                                                class="btn btn-sm btn-primary"
                                                                                style="height:36px;"
                                                                                onclick="var sel=document.querySelector('select[name=tag][form=\'addTagForm-<%= customer.id %>\']');if(sel && sel.value==='__new__')sel.value='';">Add
                                                                                Tag</button>
                                                                </div>
                                                        </div>
                                                        <% } %>

                                                                <div class="form-actions">
                                                                        <button type="submit" class="btn btn-primary">
                                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                                        width="16" height="16"
                                                                                        viewBox="0 0 24 24" fill="none"
                                                                                        stroke="currentColor"
                                                                                        stroke-width="2"
                                                                                        stroke-linecap="round"
                                                                                        stroke-linejoin="round">
                                                                                        <path
                                                                                                d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z">
                                                                                        </path>
                                                                                        <polyline
                                                                                                points="17 21 17 13 7 13 7 21">
                                                                                        </polyline>
                                                                                        <polyline points="7 3 7 8 15 8">
                                                                                        </polyline>
                                                                                </svg>
                                                                                <%= customer && customer.id
                                                                                        ? 'Update Customer'
                                                                                        : 'Create Customer' %>
                                                                        </button>
                                                                        <a href="/admin/customers"
                                                                                class="btn btn-outline">Cancel</a>
                                                                        <% if (customer && customer.id) { %>
                                                                                <form method="POST"
                                                                                        action="/admin/customers/<%= customer.id %>/delete"
                                                                                        style="display:inline;margin-left:auto;"
                                                                                        onsubmit="return confirm('Are you sure you want to delete this customer and all their orders? This action cannot be undone.')">
                                                                                        <button type="submit"
                                                                                                class="btn btn-danger">
                                                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                                                        width="14"
                                                                                                        height="14"
                                                                                                        viewBox="0 0 24 24"
                                                                                                        fill="none"
                                                                                                        stroke="currentColor"
                                                                                                        stroke-width="2"
                                                                                                        stroke-linecap="round"
                                                                                                        stroke-linejoin="round">
                                                                                                        <polyline
                                                                                                                points="3 6 5 6 21 6">
                                                                                                        </polyline>
                                                                                                        <path
                                                                                                                d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                                                                                                        </path>
                                                                                                </svg>
                                                                                                Delete
                                                                                        </button>
                                                                                </form>
                                                                                <% } %>
                                                                </div>
                                        </form>
                </div>
        </div>
        </div>

        <% if (customer && customer.id) { %>
                <form id="addTagForm-<%= customer.id %>" method="POST"
                        action="/admin/customers/<%= customer.id %>/add-tag" style="display:none;"></form>
                <form id="removeTagForm-<%= customer.id %>" method="POST"
                        action="/admin/customers/<%= customer.id %>/remove-tag" style="display:none;">
                        <input type="hidden" name="tag" id="removeTagInput-<%= customer.id %>">
                </form>
                <% } %>

                        <%- include('../layout-end') %>
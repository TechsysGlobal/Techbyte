    <link rel="stylesheet" href="/css/admin.css">
    
    <!-- GDPR Compliance: Cookie Consent Check -->
    <script>
        window.hasConsent = function(type) {
            try {
                const consent = JSON.parse(localStorage.getItem('tb_cookie_consent'));
                return consent && consent[type] === true;
            } catch (e) {
                return false;
            }
        };

        window.loadAnalytics = function() {
            if (window.hasConsent('analytics')) {
                console.log('Consent granted: Loading analytics scripts...');
                // Place future analytics loading logic here
                // Example: (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':...
            }
        };

        // Run on load
        document.addEventListener('DOMContentLoaded', window.loadAnalytics);
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

    <!-- CSRF Protection -->
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
            if (token) {
                // Auto-inject into all forms
                document.querySelectorAll('form[method="POST"]').forEach(form => {
                    if (!form.querySelector('input[name="_csrf"]')) {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = '_csrf';
                        input.value = token;
                        form.appendChild(input);
                    }
                });
                
                // Auto-inject into all fetch requests
                const originalFetch = window.fetch;
                window.fetch = function() {
                    let [resource, config] = arguments;
                    if (config && ['POST', 'PUT', 'DELETE', 'PATCH'].includes(config.method?.toUpperCase())) {
                        config.headers = {
                            ...config.headers,
                            'x-csrf-token': token
                        };
                    }
                    return originalFetch.call(this, resource, config);
                };
            }
        });
    </script>
</head>


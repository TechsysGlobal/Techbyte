<%- include('../layout-start', { pageTitle: 'Orders' }) %>

    <div class="page-actions">
        <form action="/admin/orders" method="GET" class="search-form" style="display:flex;gap:8px;align-items:center;">
            <div class="search-form" style="flex:1;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="search-icon">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" name="search" value="<%= search %>" placeholder="Search by customer or order ID..."
                    class="search-input">
            </div>
            <select name="status" class="filter-select">
                <option value="">All Statuses</option>
                <% statuses.forEach(s=> { %>
                    <option value="<%= s %>" <%=statusFilter===s ? 'selected' : '' %>><%= statusLabels[s] %>
                    </option>
                    <% }) %>
            </select>
            <button type="submit" class="btn btn-sm btn-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                Filter
            </button>
        </form>
    </div>

    <div class="card">
        <div class="card-body" style="padding:0;overflow-x:auto;">
            <% if (orders.length===0) { %>
                <p class="empty-state">No orders found.</p>
                <% } else { %>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(o=> { %>
                                <tr onclick="window.location='/admin/orders/<%= o.id %>'" style="cursor:pointer;">
                                    <td><code><%= o.id.substring(0, 8) %>...</code></td>
                                    <td>
                                        <div style="font-weight:600;">
                                            <%= o.user ? o.user.companyName : '—' %>
                                        </div>
                                        <div style="font-size:12px;color:#64748b;">
                                            <%= o.user ? o.user.email : '' %>
                                        </div>
                                    </td>
                                    <td>
                                        <%= o.items ? o.items.length : 0 %>
                                    </td>
                                    <td style="font-weight:600;">€<%= parseFloat(o.totalAmount).toFixed(2) %>
                                    </td>
                                    <td>
                                        <span class="badge badge-<%= o.currentStatus %>">
                                            <%= statusLabels[o.currentStatus] || o.currentStatus %>
                                        </span>
                                    </td>
                                    <td style="font-size:13px;color:#64748b;">
                                        <%= o.createdAt ? new Date(o.createdAt).toLocaleDateString('en-GB', {
                                            day: '2-digit' , month: 'short' , year: 'numeric' }) : '—' %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } %>
        </div>
    </div>

    <% if (totalPages> 1) { %>
        <div class="pagination">
            <% for (let i=1; i <=totalPages; i++) { %>
                <a href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= statusFilter ? '&status=' + statusFilter : '' %>"
                    class="page-btn <%= i === page ? 'active' : '' %>">
                    <%= i %>
                </a>
                <% } %>
        </div>
        <% } %>

            <style>
                .badge-confirming {
                    background: #fef3c7;
                    color: #92400e;
                    border: 1px solid #fde68a;
                }

                .badge-payment_pending {
                    background: #fef9c3;
                    color: #854d0e;
                    border: 1px solid #fde047;
                }

                .badge-ordered {
                    background: #dbeafe;
                    color: #1e40af;
                    border: 1px solid #93c5fd;
                }

                .badge-shipped {
                    background: #e0e7ff;
                    color: #3730a3;
                    border: 1px solid #a5b4fc;
                }

                .badge-delivered {
                    background: #dcfce7;
                    color: #166534;
                    border: 1px solid #86efac;
                }

                .badge-cancelled {
                    background: #fef2f2;
                    color: #991b1b;
                    border: 1px solid #fecaca;
                }

                .badge-returned {
                    background: #fff7ed;
                    color: #9a3412;
                    border: 1px solid #fed7aa;
                }

                .badge-refunded {
                    background: #f5f3ff;
                    color: #5b21b6;
                    border: 1px solid #c4b5fd;
                }
            </style>

            <%- include('../layout-end') %>
<%- include('../layout-start', { pageTitle: 'Order #' + order.id.substring(0, 8) }) %>

    <% if (typeof req !=='undefined' && req.query && req.query.error) { %>
        <div class="alert alert-error" style="margin-bottom:16px;">
            <%= req.query.error %>
        </div>
        <% } %>
        <% if (typeof req !=='undefined' && req.query && req.query.success) { %>
        <div class="alert alert-success" style="margin-bottom:16px;background:#dcfce7;color:#166534;border:1px solid #86efac;padding:12px 16px;border-radius:8px;font-size:14px;">
            <%= req.query.success %>
        </div>
        <% } %>

            <div class="page-actions">
                <div>
                    <span class="badge badge-<%= order.currentStatus %>" style="font-size:13px;padding:6px 16px;">
                        <%= statusLabels[order.currentStatus] || order.currentStatus %>
                    </span>
                    <span class="text-muted" style="margin-left:10px;">
                        <%= order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-GB', { day: '2-digit' ,
                            month: 'short' , year: 'numeric' , hour: '2-digit' , minute: '2-digit' }) : '' %>
                    </span>
                </div>
                <div style="display:flex;gap:8px;">
                    <a href="/admin/orders/<%= order.id %>/invoice" target="_blank" class="btn btn-sm btn-outline">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download Invoice
                    </a>
                    <a href="/admin/orders" class="btn btn-sm btn-outline">Back to Orders</a>
                </div>
            </div>

            <div class="detail-grid">
                <!-- Order Summary -->
                <div class="card">
                    <div class="card-header">
                        <h3>Order Summary</h3>
                    </div>
                    <div class="card-body">
                        <div class="detail-row"><span class="detail-label">Order
                                ID</span><span><code><%= order.id %></code></span></div>
                        <div class="detail-row"><span class="detail-label">Date</span><span>
                                <%= order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-GB', {
                                    day: '2-digit' , month: 'long' , year: 'numeric' }) : '—' %>
                            </span></div>
                        <div class="detail-row"><span class="detail-label">Status</span><span
                                class="badge badge-<%= order.currentStatus %>">
                                <%= statusLabels[order.currentStatus] %>
                            </span></div>
                    </div>
                </div>

                <!-- Picqer Sync Status -->
                <div class="card">
                    <div class="card-header">
                        <h3>Picqer Sync</h3>
                    </div>
                    <div class="card-body">
                        <% if (order.picqerOrderId) { %>
                            <div class="detail-row"><span class="detail-label">Picqer Order ID</span><span><code><%= order.picqerOrderId %></code></span></div>
                            <% if (order.picqerOrderNumber) { %>
                            <div class="detail-row"><span class="detail-label">Picqer Order #</span><span><code><%= order.picqerOrderNumber %></code></span></div>
                            <% } %>
                            <div class="detail-row"><span class="detail-label">Status</span><span class="badge" style="background:#dcfce7;color:#166534;border:1px solid #86efac;">Synced</span></div>
                            <div style="margin-top:12px;">
                                <form method="POST" action="/admin/orders/<%= order.id %>/retry-picqer-sync" style="display:inline;" onsubmit="return confirm('Re-sync this order to Picqer? This will create a new order in Picqer if the existing link is broken.')">
                                    <button type="submit" class="btn btn-sm btn-outline" style="font-size:12px;">Re-sync to Picqer</button>
                                </form>
                            </div>
                        <% } else { %>
                            <div class="detail-row"><span class="detail-label">Status</span><span class="badge" style="background:#fef2f2;color:#991b1b;border:1px solid #fecaca;">Not Synced</span></div>
                            <p style="font-size:13px;color:#64748b;margin:8px 0;">This order has not been pushed to Picqer. Click below to retry.</p>
                            <form method="POST" action="/admin/orders/<%= order.id %>/retry-picqer-sync">
                                <button type="submit" class="btn btn-sm btn-primary" style="background:#f59e0b;border-color:#f59e0b;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px;"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                                    Retry Picqer Sync
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>

                <!-- Customer Info -->
                <div class="card">
                    <div class="card-header">
                        <h3>Customer</h3>
                    </div>
                    <div class="card-body">
                        <% if (order.user) { %>
                            <div class="detail-row"><span class="detail-label">Company</span><span><a
                                        href="/admin/customers/<%= order.user.id %>">
                                        <%= order.user.companyName %>
                                    </a></span></div>
                            <div class="detail-row"><span class="detail-label">Email</span><span>
                                    <%= order.user.email %>
                                </span></div>
                            <div class="detail-row"><span class="detail-label">Country</span><span>
                                    <%= order.user.country || '—' %>
                                </span></div>
                            <div class="detail-row"><span class="detail-label">Address</span><span>
                                    <%= order.user.companyAddr || '—' %>
                                </span></div>
                            <% } else { %>
                                <p class="text-muted">Customer data unavailable</p>
                                <% } %>
                    </div>
                </div>
            </div>

            <!-- Order Items (Invoice-style) -->
            <div class="card" style="margin-top:24px;">
                <div class="card-header">
                    <h3>Items</h3>
                </div>
                <div class="card-body" style="padding:0;overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width:50px;">#</th>
                                <th>Product</th>
                                <th>SKU</th>
                                <th style="text-align:right;">Qty</th>
                                <th style="text-align:right;">Unit Price</th>
                                <th style="text-align:right;">Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% order.items.forEach((item, i)=> { %>
                                <tr>
                                    <td>
                                        <%= i + 1 %>
                                    </td>
                                    <td style="font-weight:500;">
                                        <%= item.product ? item.product.title : '(Deleted Product)' %>
                                    </td>
                                    <td><code><%= item.product ? item.product.variantSku : '—' %></code></td>
                                    <td style="text-align:right;">
                                        <%= item.quantity %>
                                    </td>
                                    <td style="text-align:right;">€<%= parseFloat(item.priceAtSale).toFixed(2) %>
                                    </td>
                                    <td style="text-align:right;font-weight:600;">€<%= (item.quantity *
                                            parseFloat(item.priceAtSale)).toFixed(2) %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>

                    <!-- Totals Breakdown -->
                    <div style="padding:16px 24px;border-top:2px solid #e2e8f0;">
                        <div style="max-width:300px;margin-left:auto;">
                            <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:14px;">
                                <span>Subtotal</span>
                                <span>€<%= parseFloat(order.subtotal).toFixed(2) %></span>
                            </div>
                            <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:14px;">
                                <span>VAT (<%= (order.vatRate * 100).toFixed(0) %>%)</span>
                                <span>€<%= parseFloat(order.vatPrice).toFixed(2) %></span>
                            </div>
                            <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:14px;">
                                <span>Shipping</span>
                                <span>€<%= parseFloat(order.shippingPrice).toFixed(2) %></span>
                            </div>
                            <div
                                style="display:flex;justify-content:space-between;padding:10px 0 6px;font-size:16px;font-weight:700;border-top:2px solid #1a1a2e;margin-top:6px;">
                                <span>Total</span>
                                <span>€<%= parseFloat(order.totalAmount).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Management -->
            <% if (allowedTransitions.length> 0) { %>
                <div class="card" style="margin-top:24px;">
                    <div class="card-header">
                        <h3>Update Status</h3>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="/admin/orders/<%= order.id %>/status"
                            style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
                            <div class="form-group" style="flex:1;min-width:200px;margin-bottom:0;">
                                <label for="newStatus">New Status</label>
                                <select name="newStatus" id="newStatus" class="form-select" required>
                                    <% allowedTransitions.forEach(t=> { %>
                                        <option value="<%= t %>">
                                            <%= statusLabels[t] || t %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="form-group" style="flex:2;min-width:250px;margin-bottom:0;">
                                <label for="reason">Reason / Notes (optional)</label>
                                <input type="text" name="reason" id="reason"
                                    placeholder="e.g. Payment received via bank transfer" class="form-input">
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">Update Status</button>
                        </form>
                    </div>
                </div>
                <% } %>

                    <!-- Status History Timeline -->
                    <div class="card" style="margin-top:24px;">
                        <div class="card-header">
                            <h3>Status History</h3>
                        </div>
                        <div class="card-body">
                            <% if (order.statusHistory && order.statusHistory.length> 0) { %>
                                <div style="position:relative;padding-left:24px;">
                                    <div
                                        style="position:absolute;left:8px;top:6px;bottom:6px;width:2px;background:#e2e8f0;">
                                    </div>
                                    <% order.statusHistory.forEach((h, i)=> { %>
                                        <div style="position:relative;padding-bottom:20px;">
                                            <div
                                                style="position:absolute;left:-20px;top:4px;width:12px;height:12px;border-radius:50%;background:<%= i === order.statusHistory.length - 1 ? '#36b084' : '#cbd5e1' %>;border:2px solid #fff;">
                                            </div>
                                            <div style="font-weight:600;font-size:14px;">
                                                <span class="badge badge-<%= h.status %>">
                                                    <%= statusLabels[h.status] || h.status %>
                                                </span>
                                            </div>
                                            <div style="font-size:12px;color:#64748b;margin-top:4px;">
                                                <%= h.createdAt ? new Date(h.createdAt).toLocaleString('en-GB', {
                                                    day: '2-digit' , month: 'short' , year: 'numeric' , hour: '2-digit'
                                                    , minute: '2-digit' }) : '' %>
                                                    <% if (h.details && h.details.updatedBy) { %> — by <%=
                                                            h.details.updatedBy %>
                                                            <% } %>
                                            </div>
                                            <% if (h.details && h.details.reason) { %>
                                                <div
                                                    style="font-size:13px;color:#475569;margin-top:4px;font-style:italic;">
                                                    "<%= h.details.reason %>"</div>
                                                <% } %>
                                        </div>
                                        <% }) %>
                                </div>
                                <% } else { %>
                                    <p class="text-muted">No status history recorded yet.</p>
                                    <% } %>
                        </div>
                    </div>

                    <style>
                        .badge-confirming {
                            background: #fef3c7;
                            color: #92400e;
                            border: 1px solid #fde68a;
                        }

                        .badge-payment_pending {
                            background: #fef9c3;
                            color: #854d0e;
                            border: 1px solid #fde047;
                        }

                        .badge-ordered {
                            background: #dbeafe;
                            color: #1e40af;
                            border: 1px solid #93c5fd;
                        }

                        .badge-shipped {
                            background: #e0e7ff;
                            color: #3730a3;
                            border: 1px solid #a5b4fc;
                        }

                        .badge-delivered {
                            background: #dcfce7;
                            color: #166534;
                            border: 1px solid #86efac;
                        }

                        .badge-cancelled {
                            background: #fef2f2;
                            color: #991b1b;
                            border: 1px solid #fecaca;
                        }

                        .badge-returned {
                            background: #fff7ed;
                            color: #9a3412;
                            border: 1px solid #fed7aa;
                        }

                        .badge-refunded {
                            background: #f5f3ff;
                            color: #5b21b6;
                            border: 1px solid #c4b5fd;
                        }

                        .form-select,
                        .form-input {
                            width: 100%;
                            padding: 8px 12px;
                            border: 1px solid #d1d5db;
                            border-radius: 6px;
                            font-size: 14px;
                            background: #fff;
                        }
                    </style>

                    <%- include('../layout-end') %>